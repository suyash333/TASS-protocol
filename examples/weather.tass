# ─────────────────────────────────────────────────────────────────────
# TASS — Tokeniser-Aware Structured Shorthand
# Example  : OpenWeatherMap-style current conditions + 5-slot forecast
# Source   : weather_raw.json (same directory)
# Version  : 1.0
# DOI      : 10.5281/zenodo.20403219
# ─────────────────────────────────────────────────────────────────────
#
# CONTEXT
# ───────
# A typical weather API returns ~60 fields across nested objects.
# Only a handful matter for an extraction pipeline — the rest is
# scaffolding (coord wrappers, internal IDs, icon codes, etc.).
#
# This file shows how to define a flat, LLM-facing schema that
# captures every useful value while cutting output tokens by ~80%.
# ─────────────────────────────────────────────────────────────────────


# ── DICTIONARY ───────────────────────────────────────────────────────
# Each symbol maps to one field the LLM must emit.
# Injected once into the system prompt and cached across all calls.

@dict
  ~a = city              # free-text city name
  ~b = country           # ISO-3166 alpha-2
  ~c = condition         # short weather condition (see @codes)
  ~d = temp_c            # temperature in °C, 1 decimal
  ~e = feels_like_c      # apparent temperature in °C, 1 decimal
  ~f = temp_min_c        # daily low °C
  ~g = temp_max_c        # daily high °C
  ~h = humidity          # percentage 0–100
  ~i = pressure_hpa      # surface pressure hPa
  ~j = wind_kph          # wind speed km/h, 1 decimal
  ~k = wind_dir          # compass direction (see @codes)
  ~l = wind_gust_kph     # gust speed km/h, 1 decimal
  ~m = visibility_km     # visibility in km, 1 decimal
  ~n = cloud_pct         # cloud cover percentage
  ~o = aqi               # air quality index 1–5 (WHO scale)
  ~p = pm25              # PM2.5 µg/m³, 2 decimals
  ~q = pm10              # PM10 µg/m³, 2 decimals
  ~r = sunrise_utc       # sunrise Unix timestamp
  ~s = sunset_utc        # sunset Unix timestamp
  ~t = dt                # observation/slot Unix timestamp
  ~u = pop               # probability of precipitation 0.0–1.0
@end


# ── VALUE CODES ──────────────────────────────────────────────────────
# Short tokens the LLM emits instead of full strings.
# Post-parse expansion is done server-side; the LLM never sees long labels.

@codes
  # condition
  cl  = Clear
  pc  = Partly Cloudy
  bc  = Broken Clouds
  oc  = Overcast
  hz  = Haze
  fg  = Fog
  mi  = Mist
  lr  = Light Rain
  mr  = Moderate Rain
  hr  = Heavy Rain
  ts  = Thunderstorm
  sn  = Snow
  sl  = Sleet

  # wind direction (16-point compass → 3-char code)
  N   = North
  NNE = North-Northeast
  NE  = Northeast
  ENE = East-Northeast
  E   = East
  ESE = East-Southeast
  SE  = Southeast
  SSE = South-Southeast
  S   = South
  SSW = South-Southwest
  SW  = Southwest
  WSW = West-Southwest
  W   = West
  WNW = West-Northwest
  NW  = Northwest
  NNW = North-Northwest

  # AQI labels (WHO breakpoints)
  1   = Good
  2   = Fair
  3   = Moderate
  4   = Poor
  5   = Very Poor
@end


# ── RECORDS ──────────────────────────────────────────────────────────
# Line 1   : current conditions (observation snapshot)
# Lines 2–6: 3-hourly forecast slots
#
# Field order does not matter — keys are explicit.
# Temperatures converted from Kelvin → °C by the pre-processing layer;
# wind converted from m/s → km/h (multiply by 3.6).

@records
~t:1750665600 ~a:Delhi ~b:IN ~c:hz ~d:35.0 ~e:38.3 ~f:33.3 ~g:36.7 ~h:52 ~i:1002 ~j:14.8 ~k:SW ~l:24.5 ~m:3.5 ~n:40 ~o:4 ~p:62.18 ~q:88.43 ~r:1750634220 ~s:1750683540 ~u:0.0
~t:1750676400 ~a:Delhi ~b:IN ~c:hz ~d:35.0 ~e:38.3 ~f:33.3 ~g:36.7 ~h:52 ~i:1002 ~j:14.8 ~k:SW ~l:0.0 ~m:3.5 ~n:40 ~o:4 ~p:62.18 ~q:88.43 ~r:1750634220 ~s:1750683540 ~u:0.0
~t:1750687200 ~a:Delhi ~b:IN ~c:hz ~d:37.2 ~e:40.7 ~f:35.9 ~g:38.1 ~h:48 ~i:1000 ~j:18.0 ~k:SW ~l:0.0 ~m:3.0 ~n:35 ~o:4 ~p:62.18 ~q:88.43 ~r:1750634220 ~s:1750683540 ~u:0.0
~t:1750698000 ~a:Delhi ~b:IN ~c:bc ~d:34.3 ~e:36.9 ~f:33.0 ~g:35.4 ~h:55 ~i:1001 ~j:14.0 ~k:WSW ~l:0.0 ~m:5.0 ~n:65 ~o:4 ~p:62.18 ~q:88.43 ~r:1750634220 ~s:1750683540 ~u:0.12
~t:1750708800 ~a:Delhi ~b:IN ~c:lr ~d:30.6 ~e:33.3 ~f:29.4 ~g:31.7 ~h:62 ~i:1003 ~j:22.2 ~k:S ~l:0.0 ~m:4.5 ~n:85 ~o:4 ~p:62.18 ~q:88.43 ~r:1750634220 ~s:1750683540 ~u:0.68
~t:1750719600 ~a:Delhi ~b:IN ~c:mr ~d:26.7 ~e:29.0 ~f:25.8 ~g:27.4 ~h:74 ~i:1005 ~j:26.8 ~k:S ~l:0.0 ~m:2.0 ~n:95 ~o:4 ~p:62.18 ~q:88.43 ~r:1750634220 ~s:1750683540 ~u:0.88
@end


# ── WHAT THE LLM SEES (system prompt, injected once, cached) ─────────
#
#   You are a weather extraction engine.
#   Output ONLY the TASS format below. No prose. No markdown.
#   Format: ~a:<value> ~b:<value> ~c:<value> ~d:<value> ~e:<value>
#           ~f:<value> ~g:<value> ~h:<value> ~i:<value> ~j:<value>
#           ~k:<value> ~l:<value> ~m:<value> ~n:<value> ~o:<value>
#           ~p:<value> ~q:<value> ~r:<value> ~s:<value> ~t:<value>
#           ~u:<value>
#   Dictionary:
#     ~a = city       ~b = country     ~c = condition   ~d = temp_c
#     ~e = feels_like ~f = temp_min_c  ~g = temp_max_c  ~h = humidity
#     ~i = pressure   ~j = wind_kph    ~k = wind_dir    ~l = gust_kph
#     ~m = vis_km     ~n = cloud_pct   ~o = aqi         ~p = pm25
#     ~q = pm10       ~r = sunrise     ~s = sunset      ~t = dt
#     ~u = pop
#
# ── WHAT THE LLM EMITS (one line per observation) ────────────────────
#
#   ~t:1750665600 ~a:Delhi ~b:IN ~c:hz ~d:35.0 ~e:38.3 ~f:33.3
#   ~g:36.7 ~h:52 ~i:1002 ~j:14.8 ~k:SW ~l:24.5 ~m:3.5 ~n:40
#   ~o:4 ~p:62.18 ~q:88.43 ~r:1750634220 ~s:1750683540 ~u:0.0
#
# ── TOKEN COMPARISON (o200k_base, single current-conditions record) ───
#
#   Format          Tokens    vs JSON
#   ─────────────────────────────────
#   JSON (full)       ~620    baseline
#   JSON (flat)       ~190    ↓ 69%
#   Pipe-delimited     ~68    ↓ 82%
#   TASS               ~52    ↓ 92%   ← this file's format
#
#   5-slot forecast:
#   JSON (full)      ~1,400   baseline
#   TASS (5 lines)    ~115    ↓ 92%
#
# ─────────────────────────────────────────────────────────────────────
